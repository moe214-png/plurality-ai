# Copy this file to .env, then fill in your real keys.
# Do not paste real keys into chat messages or commit them to a public repo.

CLAUDE_API_KEY=填你的_claude_key
OPENAI_API_KEY=填你的_chatgpt_key
DEEPSEEK_API_KEY=填你的_deepseek_key
GEMINI_API_KEY=填你的_gemini_key

# Optional: require a browser login before anyone can use the web panel.
# Recommended before sharing through Tailscale, Cloudflare Tunnel, ngrok, or any public URL.
PANEL_USER=panel
PANEL_PASSWORD=换成一个长一点的密码
