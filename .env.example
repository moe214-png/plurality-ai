# Copy this file to .env, then fill in your real keys.
# Do not paste real keys into chat messages or commit them to a public repo.

CLAUDE_API_KEY=填你的_claude_key
OPENAI_API_KEY=填你的_chatgpt_key
DEEPSEEK_API_KEY=填你的_deepseek_key
ZHIPU_API_KEY=填你的_智谱_key
DOUBAO_API_KEY=填你的_豆包_key

# Optional: require browser login before anyone can use the web panel.
# Users only enter a username and this invite code. Existing names log in; new names register automatically.
PANEL_MULTI_USER=true
PANEL_INVITE_CODE=换成你的邀请码
